# udev rule voor de Magnum Opus masters (ESP32 met CH340) op de Raspberry Pi.
#
# De serial-bridge detecteert masters nu ZELF op basis van de CH340 USB-id en
# routeert per master op paal_id — dus een vaste /dev/ttyMaster1-symlink of een
# poort-gebonden regel is NIET meer nodig. Deze regel zorgt alleen nog dat de
# tty-devices wereld-leesbaar/schrijfbaar zijn (MODE 0666) zodat de container
# erbij kan, ongeacht in welke USB-poort een master zit. Dit schaalt naar de
# 3 masters zonder aanpassing.
#
# Vendor 1a86 / Product 7523 = QinHeng CH340 USB-UART chip (op de ESP32 WROOM).
#
# Installatie op de Pi:
#   sudo cp config/udev/99-esp-masters.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#   (master uit- en inpluggen)
#   ls -l /dev/ttyUSB*   ← moet 0666 (crw-rw-rw-) tonen
#
# Optioneel: wil je tóch vaste symlinks per master, voeg dan regels met
# KERNELS=="<usb-poort>" + SYMLINK+="ttyMasterN" toe. Niet vereist voor werking.

SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", MODE="0666"
