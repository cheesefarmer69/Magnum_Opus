# Python bytecode-cache (mag nooit getrackt worden: regenereert lokaal en blokkeert
# anders `git pull` op de Pi met "local changes would be overwritten").
__pycache__/
*.pyc
*.pyo

# PlatformIO build-output (regenereert lokaal bij elke build; .pio/libdeps blijft
# bewust getrackt als vendored libraries).
**/.pio/build/

# Audio-dropzone: ruwe/onbenoemde WAV-drops niet committen. De README (en .gitkeep)
# blijven wel getrackt; geplaatste bestanden leven in pi/audio-player/audio/events/.
pi/audio-player/_inbox/*
!pi/audio-player/_inbox/README.md
!pi/audio-player/_inbox/.gitkeep
